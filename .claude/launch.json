{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "macro-api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "macro_positioning.api.main:app", "--host", "127.0.0.1", "--port", "8001", "--reload"],
      "port": 8001
