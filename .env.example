MPA_DATABASE_URL=sqlite:///data/macro_positioning.db
MPA_ENVIRONMENT=development
MPA_DEFAULT_HORIZON=2-12 weeks
MPA_ENABLE_HEURISTIC_EXTRACTOR=true

# FRED economic data (free, required)
MPA_FRED_API_KEY=your_fred_api_key_here

# --- BRAIN / LLM BACKENDS ---
# Primary synthesis model — Gemini (recommended)
MPA_GEMINI_API_KEY=your_gemini_api_key_here
MPA_GEMINI_MODEL=gemini-2.5-pro

# Alternative / escalation model — Claude
MPA_ANTHROPIC_API_KEY=your_anthropic_api_key_here
MPA_CLAUDE_MODEL=claude-sonnet-4-5

# Routing (optional — defaults shown)
MPA_BRAIN_PRIMARY_BACKEND=gemini
MPA_BRAIN_VISION_BACKEND=gemini
MPA_BRAIN_ESCALATION_BACKEND=anthropic

# Local Ollama (optional — dev/testing)
MPA_OLLAMA_BASE_URL=http://localhost:11434
MPA_OLLAMA_MODEL=qwen2.5:14b

# N8N webhooks → Vertex/Gemini (primary production path)
# Text synthesis (Webhook → Gemini text/message → Respond)
MPA_N8N_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/macro-brain
# Vision analysis (Webhook → Gemini image/analyze → Respond)
MPA_N8N_VISION_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/macro-brain-vision
# Audio transcription (Webhook → Gemini audio/transcribe → Respond)
MPA_N8N_AUDIO_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/macro-brain-audio

# --- PERSONAL GMAIL (Stream A) ---
# Separate OAuth from any work/shared Gmail projects.
# Run `python -c "from macro_positioning.ingestion.personal_gmail import print_setup_instructions; print_setup_instructions()"` for walkthrough.
MPA_PERSONAL_GMAIL_CLIENT_ID=
MPA_PERSONAL_GMAIL_CLIENT_SECRET=
MPA_PERSONAL_GMAIL_REFRESH_TOKEN=
MPA_PERSONAL_GMAIL_TOKEN_PATH=data/personal_gmail_token.json

# --- INTEGRATION WITH TACTICAL-EXECUTOR ---
# URL the tactical-executor uses to reach us
# MPA_TACTICAL_WEBHOOK_URL=https://trading-agent-v1-codex.onrender.com/macro/regime-update
