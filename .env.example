MPA_DATABASE_URL=sqlite:///data/macro_positioning.db
MPA_ENVIRONMENT=development
MPA_DEFAULT_HORIZON=2-12 weeks
MPA_ENABLE_HEURISTIC_EXTRACTOR=true
MPA_FRED_API_KEY=your_fred_api_key_here

# Gemini via N8N — the synthesis brain
# Text analysis: Webhook → Gemini (text/message) → Respond to Webhook
MPA_N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/macro-analyzer-gemini
# Vision/chart analysis: Webhook → Gemini (image/analyze) → Respond to Webhook
MPA_N8N_VISION_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/macro-analyzer-vision
