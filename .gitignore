# Environment and secrets
.env
.env.local

# OAuth credentials and tokens — NEVER commit these
data/personal_gmail_credentials.json
data/personal_gmail_token.json
data/*_credentials.json
data/*_token.json
**/client_secret_*.json
**/*.credentials.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Testing
.pytest_cache/

# IDE
.vscode/
.idea/

# OS
.DS_Store

# Data (keep structure, ignore generated content)
data/processed/*.md
*.db
*.db-shm
*.db-wal
data/*.zip

# Claude Code worktrees (per-session scratch, not source)
.claude/worktrees/

# N8N / runtime logs
*.log

# Training corpus — accumulating LLM call records for future fine-tuning.
# Sensitive; managed via separate sync, not git. Keep the directory marker.
training_corpus/*.jsonl
training_corpus/*.parquet
!training_corpus/.gitkeep

# Trained model artifacts — large binaries; separate strategy when these exist
src/macro_brain/models/*.bin
src/macro_brain/models/*.pt
src/macro_brain/models/*.safetensors
src/macro_brain/models/*.gguf
