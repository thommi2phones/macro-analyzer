{
  "$schema_version": "1.0",
  "description": "Canonical source registry. Supersedes newsletter_sources.json and sources.example.json. Schema is backward-compatible (adds fields, doesn't remove). Existing code may continue reading the old files until Application Agent migrates call sites in Phase 3.",
  "$migration_status": {
    "old_files": ["config/newsletter_sources.json", "config/sources.example.json"],
    "callers_to_update": [
      "src/macro_positioning/pipelines/run_pipeline.py",
      "src/macro_positioning/api/main.py",
      "src/macro_positioning/dashboard/ops_data.py"
    ],
    "code_only_definitions_to_migrate": [
      "src/macro_positioning/ingestion/podcast_rss.py:PODCAST_SOURCES (move to this file)",
      "src/macro_positioning/ingestion/gmail_connector.py:Blockworks/Weekly Wizdom (move to this file)"
    ]
  },

  "field_definitions": {
    "source_id": "Unique identifier; snake_case",
    "name": "Display name",
    "source_type": "newsletter | podcast | rss | api | gmail | manual_notes | chart",
    "author": "Optional author/host name",
    "priority": "core | secondary | trial | archived",
    "trust_weight": "0.0-1.0 prior weight; will become learned parameter once outcome data accrues",
    "market_focus": "List of macro areas this source covers",
    "routing_tags": "Tags that drive pre-tagger; determines which agents wake up (see config/source_routing.json)",
    "fetch_cadence": "ISO-8601 duration string (e.g. PT1H, P1D, P1W) or 'realtime' or 'manual'",
    "freshness_sla_hours": "How long before content is considered stale; freshness scoring decay starts here",
    "transcription_mode": "for podcasts only: 'full' | 'show_notes_only' | 'none'",
    "channels": "List of fetch channels; one source can have multiple",
    "research_style": "Free-text characterization of the source's voice",
    "validation_focus": "Which framework regimes this source is most credible on",
    "onboarded_at": "ISO date the source was added",
    "archived_at": "ISO date if archived; null if active"
  },

